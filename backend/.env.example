# Sao chep file nay thanh ".env" (bo phan .example) roi dien gia tri that vao.
# File .env se KHONG duoc dua vao Git/zip khi ban chia se project cho ai khac.

# URL cong khai cua server ban (khuyen nghi dung static domain cua ngrok de
# khong doi moi lan restart). Vi du: https://ten-domain-cua-ban.ngrok-free.app
WEBHOOK_BASE_URL=

# GitHub Personal Access Token, dung de TU DONG tao webhook qua GitHub API.
# Tao tai: https://github.com/settings/tokens
# - Classic token: chon scope "repo" (hoac it nhat "admin:repo_hook")
# - Fine-grained token: chon quyen "Webhooks: Read & write" cho repo lien quan
GITHUB_TOKEN=
